{
  "name": "danbooru-artist-search",
  "version": "0.1.0",
  "description": "Quickly screen Danbooru artists and copy them as Anima prompt tags",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Lambda-D3L7A",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.lambda.danbooru-artist-search",
    "productName": "Danbooru Artist Search",
    "artifactName": "${name}-${version}-setup.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
